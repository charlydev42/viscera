<VisceraState category="Lead" name="Cloud Nine">
  <!-- Mod1: Sine x5, glassy harmonic -->
  <PARAM id="MOD1_ON" value="1"/>
  <PARAM id="MOD1_WAVE" value="0"/>
  <PARAM id="MOD1_PITCH" value="0"/>
  <PARAM id="MOD1_KB" value="1"/>
